"""
The kind and JSON schema definition for a given workflow variable kind
"""
type WorkflowVariableSchema {
  """
  The kind of workflow variable
  """
  kind: WorkflowVariableSourceKind
  """
  JSON schema of the workflow variable
  """
  schema: JSON
