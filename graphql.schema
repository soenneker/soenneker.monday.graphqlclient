  workflowVariableKey: Int!
}

input WorkflowBlockFieldInput {
  """
  The block's field key
  """
  fieldKey: String!
  """
  Key of the workflow variable defining the configuration for the field key. Always a positive number
  """
  workflowVariableKey: Int!
}

input WorkflowBlockInput {
