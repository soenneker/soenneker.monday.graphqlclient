Defines the sorting order for returned objects in the objects query.
"""
enum OrderBy {
  CREATED_AT
  USED_AT
}

"""
Defines the visibility and access control settings for objects in the Monday.com Objects Platform.
"""
enum PrivacyKind {
  PRIVATE
  PUBLIC
}

