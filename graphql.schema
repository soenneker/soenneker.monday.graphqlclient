"""
Per-entity search namespace. Each field searches a single entity type.
"""
type SearchNamespace {
  """
  Search for items.
  """
  items(query: String!, limit: Int = 10, date_range: CrossEntityDateRangeInput, strategy: SearchStrategy, board_ids: [ID!], workspace_ids: [ID!]): SearchItemResults!
  """
  Search for boards.
  """
  boards(query: String!, limit: Int = 10, date_range: CrossEntityDateRangeInput, strategy: SearchStrategy, board_ids: [ID!], workspace_ids: [ID!]): SearchBoardResults!
  """
  Search for documents.
  """
  docs(query: String!, limit: Int = 10, date_range: CrossEntityDateRangeInput, strategy: SearchStrategy, workspace_ids: [ID!]): SearchDocResults!
  """
  Search for workspaces.
  """
  workspaces(query: String!, limit: Int = 10, date_range: CrossEntityDateRangeInput, strategy: SearchStrategy, workspace_ids: [ID!], kind: String): SearchWorkspaceResults!
}

